<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StratCanvas — Build & Backtest Trading Strategies Visually</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap');

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0a0d12;
            --bg2: #0f1319;
            --bg3: #151b24;
            --surface: #1a2230;
            --border: rgba(255, 255, 255, 0.07);
            --border2: rgba(255, 255, 255, 0.13);
            --text: #e8edf5;
            --muted: #7a8899;
            --accent: #00e5a0;
            --accent2: #0af;
            --accent3: #ff6b35;
            --gold: #f4c842;
            --serif: 'DM Serif Display', Georgia, serif;
            --sans: 'Outfit', sans-serif;
            --mono: 'DM Mono', monospace;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--sans);
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* GRID BACKGROUND */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(0, 229, 160, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 229, 160, 0.03) 1px, transparent 1px);
            background-size: 48px 48px;
            pointer-events: none;
            z-index: 0;
        }

        /* NAV */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.1rem 3rem;
            background: rgba(10, 13, 18, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }

        .logo {
            font-family: var(--serif);
            font-size: 1.4rem;
            color: var(--text);
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .logo-dot {
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 12px var(--accent);
        }

        .nav-links {
            display: flex;
            gap: 2.5rem;
            list-style: none;
        }

        .nav-links a {
            color: var(--muted);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 400;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--text);
        }

        .nav-cta {
            background: var(--accent);
            color: #0a0d12;
            padding: 0.5rem 1.3rem;
            border-radius: 6px;
            font-size: 0.875rem;
            font-weight: 600;
            text-decoration: none;
            transition: opacity 0.2s;
        }

        .nav-cta:hover {
            opacity: 0.88;
        }

        /* HERO */
        .hero {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 8rem 2rem 4rem;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(0, 229, 160, 0.08);
            border: 1px solid rgba(0, 229, 160, 0.2);
            color: var(--accent);
            font-size: 0.78rem;
            font-weight: 500;
            font-family: var(--mono);
            padding: 0.35rem 0.9rem;
            border-radius: 100px;
            margin-bottom: 2rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .badge::before {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--accent);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }

        h1 {
            font-family: var(--serif);
            font-size: clamp(3rem, 6vw, 5.5rem);
            line-height: 1.05;
            letter-spacing: -0.02em;
            color: var(--text);
            max-width: 14ch;
            margin: 0 auto 1.5rem;
        }

        h1 em {
            font-style: italic;
            color: var(--accent);
        }

        .hero-sub {
            font-size: 1.15rem;
            color: var(--muted);
            max-width: 48ch;
            margin: 0 auto 2.5rem;
            line-height: 1.7;
            font-weight: 300;
        }

        .hero-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            background: var(--accent);
            color: #0a0d12;
            padding: 0.8rem 2rem;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 30px rgba(0, 229, 160, 0.25);
        }

        .btn-ghost {
            background: transparent;
            color: var(--text);
            padding: 0.8rem 2rem;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 500;
            text-decoration: none;
            border: 1px solid var(--border2);
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-ghost:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .hero-proof {
            margin-top: 3rem;
            font-size: 0.82rem;
            color: var(--muted);
            display: flex;
            align-items: center;
            gap: 1.5rem;
            justify-content: center;
        }

        .hero-proof span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        /* CANVAS PREVIEW */
        .canvas-preview {
            position: relative;
            z-index: 1;
            margin: 0 auto;
            max-width: 1100px;
            padding: 0 2rem 6rem;
        }

        .canvas-frame {
            background: var(--bg3);
            border: 1px solid var(--border2);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 40px 120px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.04);
        }

        .canvas-topbar {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0.7rem 1.2rem;
            border-bottom: 1px solid var(--border);
            background: var(--bg2);
        }

        .traffic-lights {
            display: flex;
            gap: 6px;
        }

        .tl {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        .tl.red {
            background: #ff5f56;
        }

        .tl.yellow {
            background: #ffbd2e;
        }

        .tl.green {
            background: #27c93f;
        }

        .canvas-title {
            font-family: var(--mono);
            font-size: 0.75rem;
            color: var(--muted);
            margin-left: auto;
            margin-right: auto;
        }

        .canvas-inner {
            display: grid;
            grid-template-columns: 220px 1fr 200px;
            min-height: 440px;
        }

        /* LEFT PANEL */
        .panel-left {
            border-right: 1px solid var(--border);
            padding: 1rem;
        }

        .panel-section-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 0.6rem;
            margin-top: 0.8rem;
            padding: 0 0.3rem;
        }

        .block-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .block-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0.45rem 0.6rem;
            border-radius: 6px;
            font-size: 0.78rem;
            color: var(--muted);
            cursor: pointer;
            transition: all 0.15s;
        }

        .block-item:hover {
            background: var(--surface);
            color: var(--text);
        }

        .block-icon {
            width: 22px;
            height: 22px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            flex-shrink: 0;
        }

        .bi-green {
            background: rgba(0, 229, 160, 0.12);
            color: var(--accent);
        }

        .bi-blue {
            background: rgba(0, 170, 255, 0.12);
            color: var(--accent2);
        }

        .bi-orange {
            background: rgba(255, 107, 53, 0.12);
            color: var(--accent3);
        }

        .bi-gold {
            background: rgba(244, 200, 66, 0.12);
            color: var(--gold);
        }

        /* CENTER CANVAS */
        .canvas-area {
            position: relative;
            background: var(--bg);
            overflow: hidden;
        }

        .canvas-area svg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
        }

        /* NODE CARDS ON CANVAS */
        .nodes-layer {
            position: absolute;
            inset: 0;
        }

        .node {
            position: absolute;
            background: var(--bg3);
            border: 1px solid var(--border2);
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.73rem;
            min-width: 130px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
        }

        .node-header {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 6px;
            font-weight: 500;
            color: var(--text);
            font-size: 0.75rem;
        }

        .node-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .nd-green {
            background: var(--accent);
        }

        .nd-blue {
            background: var(--accent2);
        }

        .nd-orange {
            background: var(--accent3);
        }

        .nd-gold {
            background: var(--gold);
        }

        .node-param {
            display: flex;
            justify-content: space-between;
            color: var(--muted);
            font-family: var(--mono);
            font-size: 0.68rem;
            line-height: 1.8;
        }

        .node-param .val {
            color: var(--accent2);
        }

        .node-active {
            border-color: rgba(0, 229, 160, 0.4);
            box-shadow: 0 0 0 2px rgba(0, 229, 160, 0.12), 0 4px 20px rgba(0, 0, 0, 0.4);
        }

        /* RIGHT PANEL */
        .panel-right {
            border-left: 1px solid var(--border);
            padding: 1rem;
        }

        .stat-mini {
            background: var(--surface);
            border-radius: 6px;
            padding: 0.6rem 0.7rem;
            margin-bottom: 6px;
        }

        .stat-mini-label {
            font-size: 0.63rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 2px;
        }

        .stat-mini-val {
            font-family: var(--mono);
            font-size: 1rem;
            font-weight: 500;
            color: var(--accent);
        }

        .stat-mini-val.neg {
            color: #ff6b6b;
        }

        .mini-chart {
            height: 36px;
            margin-top: 0.5rem;
        }

        /* SECTIONS */
        section {
            position: relative;
            z-index: 1;
            padding: 6rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        .section-label {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: var(--mono);
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--accent);
            margin-bottom: 1rem;
        }

        .section-label::before {
            content: '';
            width: 20px;
            height: 1px;
            background: var(--accent);
            display: inline-block;
        }

        h2 {
            font-family: var(--serif);
            font-size: clamp(2rem, 4vw, 3rem);
            line-height: 1.1;
            letter-spacing: -0.02em;
            max-width: 20ch;
            margin-bottom: 1rem;
        }

        h2 em {
            font-style: italic;
            color: var(--muted);
        }

        .section-sub {
            color: var(--muted);
            font-size: 1.05rem;
            font-weight: 300;
            max-width: 45ch;
            margin-bottom: 3rem;
            line-height: 1.7;
        }

        /* FEATURES GRID */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
        }

        .feature-card {
            background: var(--bg);
            padding: 2rem;
            transition: background 0.2s;
        }

        .feature-card:hover {
            background: var(--bg3);
        }

        .feature-icon {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            margin-bottom: 1rem;
        }

        .feature-card h3 {
            font-size: 1rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: var(--text);
        }

        .feature-card p {
            font-size: 0.875rem;
            color: var(--muted);
            line-height: 1.65;
        }

        /* NAMES SECTION */
        .names-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .name-card {
            background: var(--bg3);
            border: 1px solid var(--border2);
            border-radius: 14px;
            padding: 1.75rem;
            transition: all 0.2s;
            cursor: default;
        }

        .name-card:hover {
            border-color: var(--accent);
            box-shadow: 0 0 0 1px rgba(0, 229, 160, 0.15);
        }

        .name-card.featured {
            border-color: rgba(0, 229, 160, 0.35);
            background: linear-gradient(135deg, rgba(0, 229, 160, 0.04), var(--bg3));
        }

        .name-tag {
            font-family: var(--mono);
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 3px 8px;
            border-radius: 4px;
            margin-bottom: 1rem;
            display: inline-block;
        }

        .tag-best {
            background: rgba(0, 229, 160, 0.1);
            color: var(--accent);
        }

        .tag-alt {
            background: rgba(255, 255, 255, 0.05);
            color: var(--muted);
        }

        .name-card h3 {
            font-family: var(--serif);
            font-size: 2rem;
            margin-bottom: 0.3rem;
            letter-spacing: -0.02em;
        }

        .domain {
            font-family: var(--mono);
            font-size: 0.8rem;
            color: var(--accent);
            margin-bottom: 0.8rem;
        }

        .name-card p {
            font-size: 0.875rem;
            color: var(--muted);
            line-height: 1.6;
            margin-bottom: 1rem;
        }

        .avail-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 0.73rem;
            padding: 4px 10px;
            border-radius: 4px;
        }

        .avail-check {
            background: rgba(0, 229, 160, 0.08);
            color: var(--accent);
            border: 1px solid rgba(0, 229, 160, 0.2);
        }

        .avail-unknown {
            background: rgba(244, 200, 66, 0.08);
            color: var(--gold);
            border: 1px solid rgba(244, 200, 66, 0.2);
        }

        /* PRICING */
        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .price-card {
            background: var(--bg3);
            border: 1px solid var(--border2);
            border-radius: 14px;
            padding: 2rem;
            transition: border-color 0.2s;
        }

        .price-card.popular {
            border-color: var(--accent);
            position: relative;
        }

        .popular-badge {
            position: absolute;
            top: -1px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--accent);
            color: #0a0d12;
            font-size: 0.68rem;
            font-weight: 700;
            font-family: var(--mono);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 4px 14px;
            border-radius: 0 0 8px 8px;
        }

        .price-plan {
            font-size: 0.8rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-family: var(--mono);
            margin-bottom: 0.8rem;
        }

        .price-amount {
            font-family: var(--serif);
            font-size: 2.8rem;
            line-height: 1;
            margin-bottom: 0.3rem;
        }

        .price-period {
            font-size: 0.8rem;
            color: var(--muted);
            margin-bottom: 1.5rem;
        }

        .price-features {
            list-style: none;
            margin-bottom: 1.5rem;
        }

        .price-features li {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            font-size: 0.85rem;
            color: var(--muted);
            margin-bottom: 0.6rem;
            line-height: 1.4;
        }

        .price-features li::before {
            content: '✓';
            color: var(--accent);
            font-size: 0.8rem;
            margin-top: 1px;
            flex-shrink: 0;
        }

        /* HOW IT WORKS */
        .steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 0;
            position: relative;
        }

        .step {
            padding: 0 2rem 2rem 0;
            position: relative;
        }

        .step-num {
            font-family: var(--mono);
            font-size: 0.7rem;
            color: var(--accent);
            background: rgba(0, 229, 160, 0.08);
            border: 1px solid rgba(0, 229, 160, 0.2);
            width: 28px;
            height: 28px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
        }

        .step h3 {
            font-size: 0.95rem;
            font-weight: 500;
            margin-bottom: 0.4rem;
            color: var(--text);
        }

        .step p {
            font-size: 0.82rem;
            color: var(--muted);
            line-height: 1.65;
        }

        /* FOOTER */
        footer {
            position: relative;
            z-index: 1;
            border-top: 1px solid var(--border);
            padding: 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        footer .logo {
            font-size: 1.1rem;
        }

        .footer-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .footer-links a {
            font-size: 0.82rem;
            color: var(--muted);
            text-decoration: none;
        }

        .footer-links a:hover {
            color: var(--text);
        }

        .footer-copy {
            font-size: 0.78rem;
            color: var(--muted);
            font-family: var(--mono);
        }

        /* GLOW ORBS */
        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.08;
            pointer-events: none;
            z-index: 0;
        }

        .orb1 {
            width: 600px;
            height: 600px;
            background: var(--accent);
            top: -200px;
            right: -200px;
        }

        .orb2 {
            width: 400px;
            height: 400px;
            background: var(--accent2);
            bottom: 20%;
            left: -150px;
        }

        /* DIVIDER */
        .divider {
            width: 100%;
            height: 1px;
            background: var(--border);
            position: relative;
            z-index: 1;
        }

        /* TICKER */
        .ticker-wrap {
            position: relative;
            z-index: 1;
            overflow: hidden;
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            padding: 0.9rem 0;
            background: var(--bg2);
        }

        .ticker-track {
            display: flex;
            gap: 3rem;
            animation: ticker 30s linear infinite;
            white-space: nowrap;
        }

        @keyframes ticker {
            from {
                transform: translateX(0);
            }

            to {
                transform: translateX(-50%);
            }
        }

        .tick-item {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: var(--mono);
            font-size: 0.78rem;
            color: var(--muted);
            flex-shrink: 0;
        }

        .tick-item .up {
            color: var(--accent);
        }

        .tick-item .dn {
            color: #ff6b6b;
        }

        /* Animated bars in mini chart */
        @keyframes barUp {
            from {
                height: 0;
            }

            to {
                height: var(--h);
            }
        }
    </style>
</head>

<body>

    <div class="orb orb1"></div>
    <div class="orb orb2"></div>

    <!-- NAV -->
    <nav>
        <div class="logo">
            <span class="logo-dot"></span>
            StratCanvas
        </div>
        <ul class="nav-links">
            <li><a href="#features">Features</a></li>
            <li><a href="#how">How it works</a></li>
            <li><a href="#pricing">Pricing</a></li>
            <li><a href="#names">About</a></li>
        </ul>
        <a href="#" class="nav-cta">Start for free →</a>
    </nav>

    <!-- TICKER -->
    <div style="height: 100px;"></div>
    <div class="ticker-wrap">
        <div class="ticker-track" id="tickerTrack"></div>
    </div>

    <!-- HERO -->
    <div class="hero">
        <div class="badge">Visual strategy builder</div>
        <h1>Build. <em>Backtest.</em> Deploy.</h1>
        <p class="hero-sub">
            Design automated trading strategies on a drag-and-drop canvas — no code required. Backtest on decades of
            market data and go live in minutes.
        </p>
        <div class="hero-actions">
            <a href="#" class="btn-primary">Start building free →</a>
            <a href="#" class="btn-ghost">▶ Watch demo</a>
        </div>
        <div class="hero-proof">
