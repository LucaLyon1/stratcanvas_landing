# Loops (transactional + lifecycle email) — https://loops.so
# Create an API key under Settings → API.
LOOPS_API_KEY=

# Optional: mailing list IDs so contacts get added to the right list.
# Find these in Loops → Audience → Mailing Lists → copy the ID.
LOOPS_WAITLIST_LIST_ID=
LOOPS_LEAD_MAGNET_LIST_ID=

# Optional: if you're using a Loops public Form instead of the API,
# you can capture the form ID here. Not used by the current /api/subscribe route.
LOOPS_FORM_ID=
