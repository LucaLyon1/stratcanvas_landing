# Mailchimp (Marketing API) — create these in your Mailchimp account
# API key: Account → Extras → API keys
# Audience ID: Audience → Settings → Audience name and defaults
# Server prefix: last part of your API key after the hyphen (e.g. us21)
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_AUDIENCE_ID=

# Optional: create matching tags in Mailchimp named exactly:
#   Waitlist
#   Lead Magnet
# (The API will usually create them on first use, depending on permissions.)
